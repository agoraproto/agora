# ──────────────────────────────────────────────────────────
# AGORA – Environment Configuration (Example)
# Kopiere zu .env und ergänze die Werte.
# Niemals .env in Git committen.
# Siehe docs/decisions/ für Hintergrund.
# ──────────────────────────────────────────────────────────

# ─── Application ───────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora_dev_change_me
POSTGRES_DB=agora
DATABASE_URL=postgresql+asyncpg://agora:agora_dev_change_me@localhost:5432/agora

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Search / Vector (optional in Bootstrap-Phase, ADR 003) ─
USE_TYPESENSE=false
USE_QDRANT=false
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=agora_dev_typesense_key
QDRANT_URL=http://localhost:6333

# ─── Auth / Custody (Privy – ADR 005) ──────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── Blockchain (in Bootstrap-Phase aus, ADR 003) ──────────
ENABLE_ONCHAIN_PAYMENTS=false
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
ESCROW_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=

# ─── Fee model (ADR 004) ───────────────────────────────────
# 1.0% mit Mindestbetrag 0,50 € und Cap 25 €
FEE_BPS=100
FEE_MIN_EUR=0.50
FEE_MAX_EUR=25.00
INSURANCE_SHARE_BPS=1000

# ─── LLM Providers (für Showcase-Agenten) ──────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Storage ───────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./var/storage

# ─── Feature Flags ─────────────────────────────────────────
ENABLE_DISPUTE=false
ENABLE_REPUTATION=true
