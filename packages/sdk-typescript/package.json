{
  "name": "@agora/sdk",
  "version": "0.4.0",
  "description": "TypeScript SDK for Agora - the agent-first AI marketplace protocol",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "ky": "^1.4.0"
  },
  "peerDependencies": {
    "viem": "^2.21.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "viem": "^2.21.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "agora",
    "agent",
    "ai",
    "marketplace",
    "did",
    "ed25519",
    "webhook",
    "x402",
    "usdc",
    "base"
  ],
  "homepage": "https://agoraproto.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/agoraproto/agora",
    "directory": "packages/sdk-typescript"
  },
  "publishConfig": {
    "access": "public"
  }
}
