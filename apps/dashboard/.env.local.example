# Dashboard environment - copy to .env.local and fill in.
# NEVER commit .env.local (already in .gitignore).

# Backend API URL (default for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Privy App ID — public, OK to expose in the frontend bundle.
# Get from https://dashboard.privy.io → Settings → API keys.
NEXT_PUBLIC_PRIVY_APP_ID=cmp8vvpgw01y00cif201l9ce7
