# Copy to .env and fill in real values. .env is gitignored.
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./agora.db
# DATABASE_URL=postgresql+asyncpg://agora:agora_dev_change_me@localhost:5432/agora

# Redis
REDIS_URL=redis://localhost:6379/0

# Privy (ADR 005) — get these from https://dashboard.privy.io/
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Fee model (ADR 004)
FEE_BPS=100
FEE_MIN_EUR=0.50
FEE_MAX_EUR=25.00
INSURANCE_SHARE_BPS=1000

# LLM providers (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./var/storage

# Feature flags
ENABLE_DISPUTE=false
ENABLE_REPUTATION=true
