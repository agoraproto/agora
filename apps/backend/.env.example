# Copy to .env and fill in real values. .env is gitignored.
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./agora.db
# DATABASE_URL=postgresql+asyncpg://agora:agora_dev_change_me@localhost:5432/agora

# Redis
REDIS_URL=redis://localhost:6379/0

# Privy (ADR 005) — get these from https://dashboard.privy.io/
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Fee model (ADR 004)
FEE_BPS=100
FEE_MIN_EUR=0.50
FEE_MAX_EUR=25.00
INSURANCE_SHARE_BPS=1000

# LLM providers (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./var/storage

# Feature flags
ENABLE_DISPUTE=false
ENABLE_REPUTATION=true

# ── Sprint 9 / ADR 009: On-chain payments (Base / USDC) ──
# Toggle the x402 + escrow surface. When false the backend ignores all
# on-chain settings and exposes only the off-chain ledger.
ENABLE_ONCHAIN_PAYMENTS=false
# Base Sepolia chain metadata is correct by default — only override for mainnet.
CHAIN_ID=84532
CHAIN_NAME=base-sepolia
RPC_URL=https://sepolia.base.org
# AgoraEscrow deployment on Base Sepolia (2026-05-18).
ESCROW_CONTRACT_ADDRESS=0xCE783B527C83c4fFFF3D3565c0F3C3204be02B76
# USDC on Base Sepolia.
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_DECIMALS=6
# Optional: platform-owned settler key for relay-mode flows.
# Leave empty for the verify-only x402 path (default).
AGORA_SETTLER_PRIVATE_KEY=
